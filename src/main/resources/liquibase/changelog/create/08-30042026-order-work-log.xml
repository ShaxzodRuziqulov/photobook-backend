<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="08-30042026-create-order-work-log-table" author="shaxzod">
        <createTable tableName="order_work_log">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="order_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_work_log_order" references="orders(id)"/>
            </column>
            <column name="employee_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_work_log_employee" references="users(id)"/>
            </column>
            <column name="step_order" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="delta" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="snapshot" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="work_month" type="VARCHAR(7)">
                <constraints nullable="false"/>
            </column>
            <column name="logged_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="order_work_log" indexName="idx_work_log_employee_month">
            <column name="employee_id"/>
            <column name="work_month"/>
        </createIndex>

        <createIndex tableName="order_work_log" indexName="idx_work_log_order">
            <column name="order_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
