<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="05-20042026-add-notification-routing" author="codex">
        <addColumn tableName="notifications">
            <column name="order_kind" type="VARCHAR(20)"/>
            <column name="target_type" type="VARCHAR(30)"/>
            <column name="target_id" type="UUID"/>
            <column name="target_kind" type="VARCHAR(30)"/>
            <column name="route" type="VARCHAR(255)"/>
        </addColumn>

        <createIndex tableName="notifications" indexName="idx_notifications_target">
            <column name="target_type"/>
            <column name="target_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
